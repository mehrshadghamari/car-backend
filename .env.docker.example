# Docker Compose — copy to .env before docker-first-run.sh
APP_HOST=http://localhost:8000
APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://car:car@postgres:5432/car_backend

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

DIVAR_REQUEST_DELAY_MS=300
DIVAR_MAX_CONCURRENT_DETAILS=10
DIVAR_EXTRA_HEADERS_JSON={}

HAMRAH_MECHANIC_BASE_URL=https://www.hamrah-mechanic.com
HAMRAH_PRICE_CACHE_TTL_SEC=3600
HAMRAH_CATALOG_CACHE_TTL_SEC=86400

KHODRO45_BASE_URL=https://khodro45.com
DEFAULT_PRICING_PLATFORM=hamrah_mechanic

SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
SMS_IR_TEMPLATE_ID=
SMS_IR_BASE_URL=https://api.sms.ir/v1

DEFAULT_POLL_INTERVAL_SEC=300
DEFAULT_NEAR_THRESHOLD_PCT=0.02
DEFAULT_MAX_PAGES_PER_RUN=5
