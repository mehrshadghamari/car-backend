# Secret staff URLs under /portal/{uuid1}/{uuid2}/…
PORTAL_PATH_UUID_1=a1b2c3d4-e5f6-7890-abcd-ef1234567890
PORTAL_PATH_UUID_2=b2c3d4e5-f6a7-8901-bcde-f12345678901

# Application
APP_HOST=http://localhost:8000
AUTH_SECRET_KEY=change-me-in-production
OTP_SANDBOX=true
OTP_SANDBOX_CODE=11111
CORS_ORIGINS=*
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
APP_ENV=development
LOG_LEVEL=INFO

# Database — SQLite (local dev, no Docker needed):
DATABASE_URL=sqlite+aiosqlite:///./data/car_backend.db
# PostgreSQL (production on VPS — see scripts/deploy/config.env)
# DATABASE_URL=postgresql+asyncpg://car-alert-dbman:12345679@localhost:5432/car_backend

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Divar crawler
DIVAR_REQUEST_DELAY_MS=300
DIVAR_MAX_CONCURRENT_DETAILS=10
DIVAR_EXTRA_HEADERS_JSON={}
DIVAR_OPEN_API_BASE_URL=https://open-api.divar.ir
# Set your Divar key here (same as local .env). For deploy: scripts/deploy/config.env
DIVAR_OPEN_API_KEY=

# Hamrah Mechanic
HAMRAH_MECHANIC_BASE_URL=https://www.hamrah-mechanic.com
HAMRAH_PRICE_CACHE_TTL_SEC=3600
HAMRAH_CATALOG_CACHE_TTL_SEC=86400
DEFAULT_PRICING_PLATFORM=hamrah_mechanic

# SMS.ir
SMS_IR_API_KEY=
SMS_IR_LINE_NUMBER=
SMS_IR_TEMPLATE_ID=
SMS_IR_BASE_URL=https://api.sms.ir/v1

# Crawl defaults
DEFAULT_POLL_INTERVAL_SEC=7200
CRAWL_POOL_REFRESH_MINUTES=120
PURCHASE_ACTIVE_DAYS=2
CRAWL_RESULT_VALID_DAYS=2
CRAWL_RESULT_DEACTIVATE_DAYS=5
PRICING_CACHE_TTL_HOURS=12
DEFAULT_NEAR_THRESHOLD_PCT=0.02
DEFAULT_MAX_PAGES_PER_RUN=5
SHARED_POOL_LISTINGS_LIMIT=150
SHARED_POOL_MAX_PAGES=10
PURCHASE_TTL_HOURS=48
