# Copy to config.env and edit before running deploy scripts.
# Source: set -a && source scripts/deploy/config.env && set +a

# Linux user that owns the app (create with: sudo adduser --disabled-password deploy)
APP_USER=deploy

# Where to clone the project on the VPS
APP_DIR=/opt/car-backend

# Public domain (DNS A record must point to this VPS)
DOMAIN=car-alert.ir

# Git repo URL (set before first deploy)
GIT_REPO=

# PostgreSQL (production VPS)
DB_NAME=car_backend
DB_USER=car-alert-dbman
DB_PASS=12345679

# Use postgres (recommended) or sqlite (minimal RAM, no Celery background jobs)
USE_POSTGRES=true

# Gunicorn workers — use 1 on 1 CPU / 2 GB RAM VPS
GUNICORN_WORKERS=1

# Let's Encrypt (certbot + nginx) — required for 06-install-ssl.sh
CERTBOT_EMAIL=mehrshad.sodoor2003@gmail.com
# Include www.DOMAIN in certificate (requires DNS A record for www)
CERTBOT_INCLUDE_WWW=false

# Run SSL step automatically at end of vps-first-deploy.sh (needs DNS ready first)
ENABLE_SSL=true

# Metabase analytics subdomain (DNS A record: meta.car-alert.ir → VPS)
METABASE_HOST=meta.car-alert.ir
